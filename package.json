{
  "name": "ai-full-duplex-interactive-voice",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx server/local.ts",
    "build": "tsc -b && vite build",
